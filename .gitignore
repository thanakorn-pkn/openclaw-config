# Track only operator-managed config in this private repo.
*
!.gitignore
!README.md
!openclaw.json
!cron/
cron/*
!cron/jobs.json

# Workspace — track all operator-managed files
!workspace/
!workspace/*.md
!workspace/scripts/
!workspace/scripts/*
!workspace/memory/
!workspace/memory/*.md
workspace/.openclaw/
